# Production env for kiteindex. Copy to .env.production and fill in values.
# .env.production is gitignored — never commit it.
#
# Usage:
#   cp .env.example .env.production
#   $EDITOR .env.production
#   docker compose --env-file .env.production up -d

# --- Required -------------------------------------------------------------

# Strong random password for the local Postgres instance. Generate with:
#   openssl rand -base64 32
POSTGRES_PASSWORD=

# Host directory containing kpass agent identity and session keys. The
# indexer container mounts this read-only at /home/ponder/.kpass so the
# gateway can authenticate real Kite Passport sessions.
# Created when you run `kpass agent register` on the host.
KPASS_CONFIG_DIR=/etc/kpass

# --- Optional overrides ---------------------------------------------------

# How far back to backfill each contract. Defaults below match what the
# Day 2 verified-events run captured. Lower = more history, slower start.
# PONDER_USDCE_START_BLOCK=76600
# PONDER_LUCID_START_BLOCK=17904
# PONDER_STAKING_START_BLOCK=17904

# Ponder log level: trace | debug | info | warn | error
# PONDER_LOG_LEVEL=info

# --- Dev only — DO NOT set in production ----------------------------------
# When KITEINDEX_FAKE_KPASS=1 is set, any X-Kite-Session header starting
# with "dev_" is treated as an active session with a 1.00 USDC budget.
# kpass.ts crashes the indexer on startup if both this and NODE_ENV=production
# are set, so the only way to use the shim is to also set NODE_ENV to
# something other than "production" (e.g. "development" or empty). Compose
# always sets NODE_ENV=production for the indexer service, so leaving this
# unset is the right default.
# KITEINDEX_FAKE_KPASS=
