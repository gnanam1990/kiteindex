# Kite Mainnet RPC. Default is the public endpoint; override with a paid /
# self-hosted endpoint in production.
PONDER_RPC_URL_2366=https://rpc.gokite.ai/

# Block to start indexing from. Defaults to a recent block in ponder.config.ts.
# PONDER_START_BLOCK=76000

# Postgres connection string. Leave unset for local dev (Ponder uses PGlite).
# DATABASE_URL=postgresql://user:pass@localhost:5432/kiteindex
